# Google Analytics 4 measurement ID (looks like "G-XXXXXXXXXX").
# Copy this file to `.env` and fill in your real ID. When empty, the
# analytics snippet is omitted, so local/dev builds stay untracked.
GA4_MEASUREMENT_ID=

# Contact form submission endpoint (POST URL from a form service such as
# Formspree, Web3Forms, or Vercel Forms). PUBLIC_ prefix exposes it to the
# client, which is required since the form posts from the browser. Until this
# is set, the contact form has no submit target. Configure the service to
# redirect to /thank-you on success (the form sends this as a `_next` hidden
# field, which Formspree honours).
PUBLIC_CONTACT_ENDPOINT=
