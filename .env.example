# Google Analytics 4 measurement ID (looks like "G-XXXXXXXXXX").
# Copy this file to `.env` and fill in your real ID. When empty, the
# analytics snippet is omitted, so local/dev builds stay untracked.
GA4_MEASUREMENT_ID=

# --- Contact form (/api/contact) -------------------------------------------

# Resend API key used to send contact-form notification emails.
# Create one at https://resend.com/api-keys
RESEND_API_KEY=

# Address that receives contact-form notifications (where Resend delivers to).
CONTACT_EMAIL=

# Cloudflare Turnstile keys (spam protection). Create a widget at
# https://dash.cloudflare.com/?to=/:account/turnstile
# The SITE key is public (rendered into the page); the SECRET key is used only
# server-side to verify submissions and must never be exposed to the client.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
