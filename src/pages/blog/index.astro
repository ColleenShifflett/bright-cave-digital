---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title="Blog"
  description="Insights, guides, and updates from Brightcave Digital."
>
  <section class="page-head">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Blog</p>
        <h2>Insights &amp; field notes.</h2>
        <p class="sub">Practical guidance on growing your business online.</p>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="wrap" style="max-width: 820px;">
      {posts.length === 0 && <p style="text-align:center;color:var(--bca-fg-muted);">No posts yet — check back soon.</p>}

      <ul class="post-list">
        {
          posts.map((post) => (
            <li>
              <article class="card">
                <h2><a href={`/blog/${post.id}/`}>{post.data.title}</a></h2>
                <p class="meta">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {dateFmt.format(post.data.pubDate)}
                  </time>
                  {post.data.author && <> &middot; {post.data.author}</>}
                </p>
                <p>{post.data.description}</p>
                <p class="card-cta"><a href={`/blog/${post.id}/`}>Read more →</a></p>
              </article>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
