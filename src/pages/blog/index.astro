---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title="Blog"
  description="Insights, guides, and updates from Brightcave Digital."
>
  <h1>Blog</h1>
  <p>Insights, guides, and updates on growing your business online.</p>

  {posts.length === 0 && <p>No posts yet — check back soon.</p>}

  <ul>
    {
      posts.map((post) => (
        <li>
          <article>
            <h2><a href={`/blog/${post.id}/`}>{post.data.title}</a></h2>
            <p>
              <time datetime={post.data.pubDate.toISOString()}>
                {dateFmt.format(post.data.pubDate)}
              </time>
              {post.data.author && <> &middot; {post.data.author}</>}
            </p>
            <p>{post.data.description}</p>
          </article>
        </li>
      ))
    }
  </ul>
</BaseLayout>
