---
import BaseLayout from '../layouts/BaseLayout.astro';

const tiers = [
  {
    id: 'diy',
    code: 'DIY',
    name: 'Do It Yourself',
    gem: 'gem--clarity',
    intro:
      'For the hands-on business owner who wants to learn and build independently.',
    includes: [
      'Step-by-step guides and templates',
      'Self-paced courses and playbooks',
      'A growing library of free resources',
      'Community support',
    ],
    feature: false,
  },
  {
    id: 'dwy',
    code: 'DWY',
    name: 'Done With You',
    gem: 'gem--glow',
    intro:
      'For teams who want expert guidance while keeping their hands on the wheel.',
    includes: [
      'One-on-one strategy sessions',
      'Coaching and accountability',
      'Reviews and feedback on your work',
      'Custom roadmaps and priorities',
    ],
    feature: true,
  },
  {
    id: 'dfy',
    code: 'DFY',
    name: 'Done For You',
    gem: 'gem--insight',
    intro:
      'For businesses that want results without the workload — we handle everything.',
    includes: [
      'Full-service strategy and execution',
      'Content, campaigns, and creative',
      'Ongoing management and reporting',
      'A dedicated point of contact',
    ],
    feature: false,
  },
];
---

<BaseLayout
  title="Services"
  description="Brightcave Digital's DIY, Done-With-You, and Done-For-You services — pick the level of support that fits how you want to work."
>
  <section class="page-head">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Services</p>
        <h2>Three shapes of support.</h2>
        <p class="sub">
          Every engagement starts with one question: how much do you want to do
          yourself? Pick the tier that fits today — you can always move between
          them as your needs change.
        </p>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="wrap">
      <div class="card-grid">
        {
          tiers.map((tier) => (
            <article id={tier.id} class={`card${tier.feature ? ' dark' : ''}`}>
              {tier.feature && <span class="badge" style="align-self:flex-start;color:var(--bca-glow);border-color:rgba(255,255,255,0.3);">Most popular</span>}
              <span class={`gem ${tier.gem}`} aria-hidden="true" />
              <span class="tier-code">{tier.code}</span>
              <h3>{tier.name}</h3>
              <p>{tier.intro}</p>
              <ul>
                {tier.includes.map((item) => <li>{item}</li>)}
              </ul>
              <p class="card-cta">
                <a
                  class={`btn ${tier.feature ? 'btn-accent' : 'btn-ghost'}`}
                  href="/#contact"
                >
                  Get started
                </a>
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="cta-band" id="contact">
    <div class="wrap">
      <h2>Not sure which is right?</h2>
      <p>
        This is placeholder copy. Add a contact form or booking link here so
        prospects can get in touch.
      </p>
      <a class="btn btn-primary" href="/about" style="padding:14px 24px;font-size:15px;">Learn about us →</a>
    </div>
  </section>
</BaseLayout>
