---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { articleSchema } from '../../lib/jsonld';
import { DEFAULT_OG_IMAGE, SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
  const resources = await getCollection('resources', ({ data }) => !data.draft);
  return resources.map((resource) => ({
    params: { slug: resource.id },
    props: { resource },
  }));
}

type Props = { resource: CollectionEntry<'resources'> };

const { resource } = Astro.props;
const { Content } = await render(resource);
const { data } = resource;

const url = new URL(Astro.url.pathname, Astro.site);
const image = data.ogImage ?? DEFAULT_OG_IMAGE;

const schema = articleSchema({
  title: data.title,
  description: data.description,
  url,
  image: new URL(image, Astro.site),
  publishedTime: data.pubDate,
  modifiedTime: data.updatedDate,
  author: SITE_TITLE,
});
---

<BaseLayout
  title={data.title}
  description={data.description}
  image={image}
  type="article"
  publishedTime={data.pubDate}
  modifiedTime={data.updatedDate}
  schema={[schema]}
>
  <section class="page-head">
    <div class="wrap">
      <header class="article-header">
        <span class="badge">{data.resourceType}{data.tier ? ` · For ${data.tier}` : ''}</span>
        <h1>{data.title}</h1>
        <p class="meta">{data.description}</p>
      </header>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="wrap">
      <article class="prose">
        <Content />
        {
          data.downloadUrl && (
            <p>
              <a class="btn btn-accent" href={data.downloadUrl} rel="noopener">
                Download this resource
              </a>
            </p>
          )
        }
      </article>
      <div class="prose">
        <a class="back-link" href="/resources">← Back to resources</a>
      </div>
    </div>
  </section>
</BaseLayout>
