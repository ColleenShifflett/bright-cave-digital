---
import SEO from '../components/SEO.astro';
import JsonLd from '../components/JsonLd.astro';
import Analytics from '../components/Analytics.astro';
import { organizationSchema } from '../lib/jsonld';
import { SITE_TITLE, SITE_URL, NAV_LINKS } from '../consts';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  /** Extra schema.org objects to embed (e.g. Article schema). */
  schema?: Record<string, unknown>[];
}

const { schema = [], ...seo } = Astro.props;

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE_TITLE}
      href={new URL('rss.xml', SITE_URL)}
    />
    <meta name="generator" content={Astro.generator} />

    <SEO {...seo} />

    <!-- Organization structured data (sitewide) -->
    <JsonLd schema={organizationSchema()} />
    <!-- Page-specific structured data (e.g. Article) -->
    {schema.map((s) => <JsonLd schema={s} />)}

    <!-- Analytics (GA4 via Partytown) -->
    <Analytics />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header>
      <nav aria-label="Primary">
        <a href="/" class="brand">{SITE_TITLE}</a>
        <ul>
          {
            NAV_LINKS.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-current={isActive(link.href) ? 'page' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer>
      <p>
        &copy; {new Date().getFullYear()} {SITE_TITLE}. All rights reserved.
      </p>
      <p>
        <a href="/blog">Blog</a> &middot;
        <a href="/resources">Resources</a> &middot;
        <a href="/rss.xml">RSS</a> &middot;
        <a href="/sitemap-index.xml">Sitemap</a>
      </p>
    </footer>

    <style>
      /* Minimal, unopinionated resets only — no styling framework yet. */
      .skip-link {
        position: absolute;
        left: -9999px;
      }
      .skip-link:focus {
        left: 0;
        top: 0;
      }
    </style>
  </body>
</html>
